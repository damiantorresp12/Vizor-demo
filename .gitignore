# Editor / local tooling
.claude/
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs / temp
*.log
*.tmp
node_modules/

# Build artifacts (none in this project, but just in case)
dist/
build/
.vercel/

# Internal session docs (not part of the site)
HANDOFF.md

# Local secrets (Cloudinary API creds, etc.)
.env
.env.local

# Source images for the portfolio (800+ MB). The site references the Cloudinary
# copies via URLs in assets/data/portfolio.json -- the local originals are not
# needed at runtime. Re-upload to Cloudinary if you ever need to regenerate.
assets/img/portfolio/

# Local source files for VRs and animations -- uploaded to Cloudinary, then
# the URLs live in assets/data/{vrs,animations}.json. The originals do not
# need to be in the repo.
assets/img/vr-source/
assets/video/anim-source/

# Intermediate build artifact from upload-to-cloudinary.ps1 -- regenerable.
tools/upload-results.json

